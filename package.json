{
  "name": "agentkitforge-core",
  "version": "1.0.0",
  "description": "Core package, validation, export, and packaging engine for AgentKitForge.",
  "type": "module",
  "bin": {
    "agentkitforge": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "builder",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "agentkit",
    "agents",
    "validation",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^14.0.2",
    "jszip": "^3.10.1",
    "yaml": "^2.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=26"
  }
}
